using System.Text.Json;

public static class DictHelper
{
    public static string GetString(this Dictionary<string, object> dict, string key, string defaultValue = "")
    {
        if (dict == null || !dict.TryGetValue(key, out var raw) || raw == null)
            return defaultValue;

        if (raw is JsonElement element)
        {
            return element.ValueKind switch
            {
                JsonValueKind.String => element.GetString(),
                JsonValueKind.Number => element.ToString(),  // safe: "23"
                JsonValueKind.True   => "true",
                JsonValueKind.False  => "false",
                JsonValueKind.Null   => defaultValue,
                _ => element.ToString()
            };
        }

        return raw.ToString() ?? defaultValue;
    }
}

private object NormalizeValue(
    ActiveColumnConfig col,
    object? value)
{
    // Plain text column
    if (col.DataType == "text")
    {
        return value?.ToString() ?? string.Empty;
    }

    // Multi-select column
    if (col.DataType == "multi_select")
    {
        // already parsed list
        if (value is List<string> list)
        {
            return list;
        }

        // if DB/json deserializer gave string[]
        if (value is string[] array)
        {
            return array.ToList();
        }

        // if stored as JSON text in dictionary
        if (value is string json && !string.IsNullOrWhiteSpace(json))
        {
            try
            {
                return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json)
                       ?? new List<string>();
            }
            catch
            {
                return new List<string>();
            }
        }

        return new List<string>();
    }

    return value ?? string.Empty;
}
